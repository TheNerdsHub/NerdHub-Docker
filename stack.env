# Environment variables for the Docker stack
# It is recommended to override these default settings

# MongoDB settings
MONGODB_PORT=27017
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root

# Backend settings
BACKEND_PORT=5000
BACKEND_MONGO_URI=mongodb://BACKEND_MONGO_URI_HERE
BACKEND_STEAM_API_KEY=API_KEY_HERE
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-production-frontend.com

# Frontend settings
FRONTEND_PORT=3000
API_URL_EXTERNAL=http://172.20.0.2:80

# Discord Bot settings
DISCORD_BOT_TOKEN=YOUR_TOKEN_HERE
API_URL_INTERNAL=http://172.20.0.2:80